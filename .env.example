# ============================================
# Backend 환경변수 (backend/.env 또는 Railway 환경변수)
# ============================================

# 데이터베이스 URL
# - 로컬 (SQLite): sqlite:///./finance_dashboard.db
# - 로컬 (PostgreSQL): postgresql://postgres:postgres@localhost:5432/finance_dashboard
# - Railway: 자동 제공됨 (PostgreSQL 플러그인 추가 시)
DATABASE_URL=sqlite:///./finance_dashboard.db

# CORS 허용 도메인 (쉼표로 여러 개 가능)
# - 로컬: http://localhost:5173
# - 배포: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ============================================
# Frontend 환경변수 (frontend/.env.local)
# ============================================

# 백엔드 API URL (빈 값이면 같은 도메인 사용)
# - 로컬: 빈 값 (vite proxy가 처리)
# - 배포: https://your-app.up.railway.app
# VITE_API_URL=
